# Django
SECRET_KEY=change-me-in-production
STAXREAD_FERNET_KEY=change-me-32-bytes-base64-encoded
DEBUG=true

# Set this to the hostname or IP address used to access StaxRead on your network.
# Used to generate the self-signed SSL certificate (SAN) and for Django security headers.
# Examples:
#   192.168.1.50          (LAN IP — most common for home/office self-hosting)
#   staxread.local        (local DNS name)
#   staxread.acme.org     (internal company domain)
STAXREAD_DOMAIN=localhost

# Must include STAXREAD_DOMAIN (and localhost / 127.0.0.1 for local access).
ALLOWED_HOSTS=localhost,127.0.0.1

# Must include the HTTPS origin matching STAXREAD_DOMAIN.
CSRF_TRUSTED_ORIGINS=https://localhost

# SSL Certificate Generation
# Key algorithm: EC (elliptic curve, default) or RSA
CERT_ALGO=EC
# EC: curve name — prime256v1 (P-256, default) or secp384r1 (P-384)
# RSA: key size in bits — 2048 or 4096
CERT_KEY_PARAM=prime256v1
# Validity period in days
CERT_DAYS=365
# Subject fields
CERT_COUNTRY=NL
CERT_ORG=StaxRead
# Additional Subject Alternative Names beyond STAXREAD_DOMAIN, comma-separated.
# Include localhost and 127.0.0.1 to allow local browser access alongside LAN access.
# Example: DNS:localhost,IP:127.0.0.1,DNS:staxread.local
CERT_EXTRA_SANS=DNS:localhost,IP:127.0.0.1

# Database
POSTGRES_USER=staxread
POSTGRES_PASSWORD=staxread
POSTGRES_DB=staxread
DATABASE_URL=postgres://staxread:staxread@postgres:5432/staxread

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=staxread
MINIO_SECRET_KEY=staxread-secret
MINIO_BUCKET=staxread-documents
MINIO_USE_SSL=false
